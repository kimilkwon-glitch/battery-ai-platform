# Battery Manager — 환경변수 예시 (실제 값은 Vercel / .env.local에만 설정, Git 커밋 금지)

# ── Postgres (Neon / Vercel Postgres — 자사몰 주문·결제 영구 저장, production 필수) ──
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── 관리자 인증 (production 필수) ──
ADMIN_USERNAME=your-admin-id
# 권장: node scripts/hash-admin-password.mjs "your-password" 출력값
ADMIN_PASSWORD_HASH=scrypt:xxxxxxxx:xxxxxxxx
# 또는 긴급 적용 시 평문(비권장): ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=long-random-secret-for-session-hmac

# (선택) CI·서버 스크립트용 API 키 — x-admin-key 헤더
# ADMIN_API_KEY=optional-ci-key

# @deprecated 1차 호환 — 신규 배포에서는 위 변수 사용
# ADMIN_ACCESS_KEY=legacy-only

# ── 토스페이먼츠 (테스트 키부터 적용, Git 커밋 금지) ──
PAYMENT_PROVIDER=toss
# 결제위젯 클라이언트 키 (브라우저 노출 — test_gck_ 또는 live_gck_)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm
# 결제 승인 시크릿 키 (서버 전용 — test_gsk_ 또는 live_gsk_)
TOSS_SECRET_KEY=test_gsk_docs_OaPz8L5KdmQXkzR3n07xlzm
# TOSS_API_BASE_URL=https://api.tosspayments.com
# NEXT_PUBLIC_SITE_URL=https://battery-ai-platform.vercel.app
# COMMERCE_ORDERS_DISABLED=true

# ── 사업자 정보 (푸터·회사소개·토스 심사 — production에서 실제 값으로 교체) ──
# NEXT_PUBLIC_COMPANY_TRADE_NAME=배터리매니저
# NEXT_PUBLIC_COMPANY_CEO=
# NEXT_PUBLIC_COMPANY_BUSINESS_NO=
# NEXT_PUBLIC_COMPANY_MAIL_ORDER_NO=
# NEXT_PUBLIC_COMPANY_ADDRESS=
# NEXT_PUBLIC_COMPANY_EMAIL=
# NEXT_PUBLIC_COMPANY_PRIVACY_OFFICER=
# NEXT_PUBLIC_COMPANY_HOURS=평일 09:00–18:00 (점심 12:00–13:00)
