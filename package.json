{
  "name": "battery-ai-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/generate-ai-audit-snapshot.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "brand-logos": "node scripts/convert-brand-logos.mjs",
    "brand-logos:light": "node scripts/export-brand-banner-logos-light.mjs",
    "normalize:cars": "node scripts/normalize-car-assets.mjs",
    "normalize:vehicles": "node scripts/normalize-all-vehicle-assets.mjs",
    "normalize:chevrolet": "node scripts/normalize-chevrolet-car-assets.mjs",
    "generate:mock-activity": "npx tsx scripts/generate-mock-activity.ts",
    "generate:content-workbench": "npx tsx scripts/generate-content-workbench.ts",
    "ux:audit:quick": "node tools/ux-audit/run-cli.mjs 30",
    "ux:audit": "node tools/ux-audit/run-cli.mjs 100",
    "ux:audit:full": "node tools/ux-audit/run-cli.mjs 500",
    "ux:audit:headed": "node tools/ux-audit/run-cli.mjs 30 --headed",
    "ux:audit:report": "playwright show-report tools/ux-audit/playwright-report",
    "ux:audit:clean": "node tools/ux-audit/cleanReports.js",
    "verify:porter2": "npx tsx scripts/verify-porter2-regression.mjs",
    "verify:production": "node scripts/verify-production-evidence.mjs",
    "search:qa": "node tools/search-quality/run-search-quality.mjs",
    "verify:alias-v01": "node tools/verify-alias-v01-production.mjs",
    "verify:alias-v021": "npx tsx scripts/probe-vehicle-alias-v021.mjs",
    "verify:alias-v03": "npx tsx scripts/probe-vehicle-alias-v03.mjs",
    "audit:vehicle-db": "npx tsx tools/audit-vehicle-db-integrity.ts",
    "audit:vehicle-generation": "npx tsx tools/audit-vehicle-generation-match.ts",
    "merge:source-tables": "npx tsx tools/merge-source-tables-into-vehicle-db.ts",
    "report:unmatched-assets": "npx tsx tools/generate-unmatched-assets-review.ts",
    "audit:battery-match": "npx tsx tools/audit-battery-match-status.ts && npx tsx tools/audit-battery-match-v2-final.ts && npx tsx tools/audit-ev-low-voltage-policy.ts",
    "audit:vehicle-battery-sources": "npx tsx tools/audit-full-vehicle-battery-sources.ts",
    "audit:vehicle-images": "npx tsx tools/audit-vehicle-image-assets.ts",
    "audit:vehicle-image-master-list": "npx tsx tools/audit-vehicle-image-master-list.ts",
    "restore:damaged-vehicle-images": "node scripts/restore-damaged-vehicle-images.mjs",
    "generate:test-vehicle-images": "node scripts/generate-test-vehicle-images-replicate.mjs --model=flux-1.1-pro",
    "generate:test-vehicle-images:dev": "node scripts/generate-test-vehicle-images-replicate.mjs --model=flux-dev",
    "collect:vehicle-reference-candidates": "node scripts/collect-vehicle-reference-candidates.mjs",
    "check:replicate-reference-models": "node scripts/check-replicate-reference-models.mjs",
    "generate:reference-based-vehicle-images": "node scripts/generate-reference-based-vehicle-images.mjs",
    "prepare:kontext-test2-candidates": "node scripts/prepare-kontext-test2-candidates.mjs",
    "check:replicate-kontext-model": "node scripts/check-replicate-kontext-model.mjs",
    "generate:reference-based-kontext-images": "node scripts/generate-reference-based-kontext-images.mjs",
    "prepare:kontext-next3-candidates": "node scripts/prepare-kontext-next3-candidates.mjs",
    "check:replicate-kontext-model-next3": "node scripts/check-replicate-kontext-model-next3.mjs",
    "generate:reference-based-kontext-next3-images": "node scripts/generate-reference-based-kontext-next3-images.mjs",
    "audit:operational": "node tools/generate-operational-audit.mjs",
    "e2e:customer-flow": "node tools/e2e-customer-flow-check.mjs",
    "audit:button-actions": "node tools/audit-button-actions.mjs",
    "audit:full-ux": "node tools/full-customer-ux-audit.mjs",
    "db:migrate:commerce": "npx tsx scripts/migrate-commerce-db.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@tabler/icons-react": "^3.44.0",
    "@tosspayments/tosspayments-sdk": "^2.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "latest",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "latest",
    "react-dom": "latest",
    "replicate": "^1.4.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.8.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "latest",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "pdf-to-img": "^6.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "latest",
    "typescript": "latest",
    "xlsx": "^0.18.5"
  }
}
